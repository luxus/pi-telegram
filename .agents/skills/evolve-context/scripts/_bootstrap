#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
INSTALL_DIR="${HOME}/.local/bin"

SOURCE_VALIDATOR="${SCRIPT_DIR}/validate-context"
TARGET_VALIDATOR="${INSTALL_DIR}/validate-context"

OS_TYPE="$(uname -s)"
case "$OS_TYPE" in
  Linux|Darwin)
    ;;
  *)
    echo "ERROR: Unsupported OS: ${OS_TYPE}" >&2
    echo "This skill supports Linux and macOS only." >&2
    exit 1
    ;;
esac

echo "=== evolve-context bootstrap ==="
echo "Platform: ${OS_TYPE}"

if [[ ! -f "$SOURCE_VALIDATOR" ]]; then
  echo "ERROR: missing script: $SOURCE_VALIDATOR" >&2
  exit 1
fi

mkdir -p "$INSTALL_DIR"
cp "$SOURCE_VALIDATOR" "$TARGET_VALIDATOR"
chmod +x "$TARGET_VALIDATOR"

echo "✓ Installed: $TARGET_VALIDATOR"

if [[ ":${PATH}:" != *":${INSTALL_DIR}:"* ]]; then
  echo "Add to PATH: export PATH=\"${INSTALL_DIR}:\$PATH\""
else
  echo "✓ PATH already includes ${INSTALL_DIR}"
fi

echo "Ready: run 'validate-context' from a project root to audit documentation health."
